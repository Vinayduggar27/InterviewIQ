generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String

  role         String?
  experience   String?
  skills       String?
  avatar       String?

  university   String?
  course        String?
  github        String?
  linkedin      String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interviews      Interview[]
  resumeAnalyses  ResumeAnalysis[]
}
  

model Interview {
  id          String   @id @default(cuid())
  role        String
  company     String
  experience  Int
  techStack   String
  questions   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  overallScore        Int?
technicalScore      Int?
communicationScore  Int?
confidenceScore     Int?

feedback            String?

strengths           Json?
weaknesses          Json?

answers             Json?

completedAt         DateTime?
}

model ResumeAnalysis {
  id               String   @id @default(cuid())
  atsScore         Int
  strengths        Json
  weaknesses       Json
  missingKeywords  Json
  suggestions      Json

  createdAt        DateTime @default(now())

  userId           String
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
}